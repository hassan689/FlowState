# MASS (Flowstate) Backend - Environment template
# Copy to .env and fill values

DEBUG=0
SECRET_KEY=your-secret-key-min-50-chars-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,.example.com

# App + tests use asyncpg (postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://flowstate:password@localhost:5432/flowstate
# Dedicated DB for pytest (recommended so tests can drop/recreate schema safely)
TEST_DATABASE_URL=postgresql+asyncpg://flowstate:password@localhost:5432/flowstate_test
REDIS_URL=redis://localhost:6379/0
CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0

JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

CORS_ALLOWED_ORIGINS=https://your-frontend.com,http://localhost:3000
