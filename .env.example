DEBUG=0
SECRET_KEY=mysecretkey123
ALLOWED_HOSTS=localhost,127.0.0.1,.example.com

# App + tests use asyncpg (postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://flowstate:123456@localhost:5432/flowstate
# Dedicated DB for pytest (recommended so tests can drop/recreate schema safely)
TEST_DATABASE_URL=postgresql+asyncpg://flowstate:123456@localhost:5432/flowstate
REDIS_URL=redis://localhost:6379/0
CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0

# Optional: override sklearn artifact paths (defaults under app/ml/models/)
# ML_STATE_MODEL_PATH=C:\path\to\state_classifier.joblib
# ML_EFFORT_MODEL_PATH=C:\path\to\effort_regressor.joblib

JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

CORS_ALLOWED_ORIGINS=https://your-frontend.com,http://localhost:3000
